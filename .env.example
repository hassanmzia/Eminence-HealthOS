# =============================================================================
# Eminence HealthOS — Environment Configuration
# =============================================================================
# Copy to .env and fill in values

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=eminence-healthos
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://healthos:healthos@localhost:5432/healthos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6279/0
REDIS_CACHE_TTL=300

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=healthos-agents
KAFKA_VITALS_TOPIC=vitals.ingested
KAFKA_ALERTS_TOPIC=alerts.generated
KAFKA_AGENT_EVENTS_TOPIC=agent.events

# ─── LLM Providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:12434

# Default LLM provider: anthropic | openai | ollama
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514

# ─── Vector Database (Qdrant) ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Neo4j Knowledge Graph ──────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=healthos

# ─── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Object Storage (MinIO/S3) ──────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=healthos-artifacts
