# ── HealthOS Configuration ────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
APP_NAME=eminence-healthos
APP_VERSION=0.1.0

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://healthos:healthos@postgres:5432/healthos
DATABASE_SYNC_URL=postgresql://healthos:healthos@postgres:5432/healthos
POSTGRES_USER=healthos
POSTGRES_PASSWORD=healthos
POSTGRES_DB=healthos

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# ── Kafka ────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=healthos-agents

# ── Neo4j (Knowledge Graph) ─────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=healthos-neo4j

# ── Qdrant (Vector Store) ───────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── LLM Providers ───────────────────────────────────────────────────
# Anthropic (Primary)
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# OpenAI (Fallback)
OPENAI_API_KEY=

# Local (Ollama)
OLLAMA_BASE_URL=http://ollama:11434

# ── Auth (Keycloak) ─────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=healthos
KEYCLOAK_CLIENT_ID=healthos-api
KEYCLOAK_CLIENT_SECRET=change-me

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Observability ────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=healthos-agents
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=healthos

# ── Multi-Tenant ─────────────────────────────────────────────────────
DEFAULT_TENANT_ID=default
TENANT_HEADER=X-Tenant-ID

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Encryption ───────────────────────────────────────────────────────
PHI_ENCRYPTION_KEY=change-me-32-byte-key-for-aes256
